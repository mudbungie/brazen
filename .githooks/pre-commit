#!/bin/sh
# brazen pre-commit gate:
#   `make check` (fmt-check + clippy + 300-line cap + 100% coverage), once Rust
#   sources exist. Runs on plain `git commit` and on `bl close` delivery.
# Delegates wholly to `make check` so the Makefile stays the single source of
# truth for *what* "the gate" is (the 300-line cap lives once, in `make
# linecount`, which `make check` runs); this hook only decides *when* it runs.
# Keep it POSIX sh.
set -eu

# Full gate (fmt-check + clippy + 300-line cap + 100% cov), only when Rust exists.
if find src -name '*.rs' 2>/dev/null | grep -q .; then
	if ! command -v cargo-llvm-cov >/dev/null 2>&1; then
		echo "pre-commit: cargo-llvm-cov is required to enforce 100% coverage." >&2
		echo "            install it with: cargo install cargo-llvm-cov" >&2
		exit 1
	fi
	echo "pre-commit: running full gate (fmt-check + clippy + 100% coverage)..." >&2
	make check >&2
fi

exit 0

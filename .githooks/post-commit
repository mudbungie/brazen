#!/bin/sh
# brazen post-commit: auto-push main to origin.
# Fires after every commit; acts only when the commit landed on main (skips
# detached HEAD and work/<id> worktree branches, so `bl close` delivery is the
# normal trigger). A failed push (offline, rejected) warns on stderr and never
# blocks — post-commit cannot abort the commit, and this hook keeps it that way.
# Keep it POSIX sh.
set -u

branch=$(git symbolic-ref -q --short HEAD) || exit 0
[ "$branch" = "main" ] || exit 0

if git push origin main >&2; then
	echo "post-commit: pushed main to origin" >&2
else
	echo "post-commit: WARNING: push to origin failed; push manually with: git push origin main" >&2
fi

exit 0
